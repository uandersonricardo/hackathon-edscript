{
  "expo": {
    "name": "Esportes da Sorte",
    "slug": "esportes-da-sorte",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "esportesdasorte",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.esportes-da-sorte"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#023697",
        "foregroundImage": "./assets/images/icon.png",
        "backgroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.esportesdasorte"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 256,
          "resizeMode": "contain",
          "backgroundColor": "#023697",
          "dark": {
            "backgroundColor": "#023697"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4916da14-9f5d-4ab2-876a-1a6dec62e0c0"
      }
    }
  }
}
